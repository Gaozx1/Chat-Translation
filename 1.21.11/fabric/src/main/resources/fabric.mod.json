{
  "schemaVersion": 1,
  "id": "chattranslation",
  "version": "${version}",
  "name": "Chat Translation",
  "description": "Real-time client-side chat translation mod with free translation providers and optional AI-compatible endpoints.",
  "authors": ["Gaozx1"],
  "contact": {
    "homepage": "https://github.com/Gaozx1/Chat-Translation",
    "sources": "https://github.com/Gaozx1/Chat-Translation",
    "issues": "https://github.com/Gaozx1/Chat-Translation/issues"
  },
  "license": "MIT",
  "icon": "assets/chattranslation/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.chattranslation.ChatTranslationMod"
    ],
    "modmenu": [
      "com.chattranslation.config.ModMenuIntegration"
    ]
  },
  "depends": {
    "fabricloader": ">=0.15.0",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": ">=0.104.0",
    "cloth-config": ">=16.0.141"
  },
  "recommends": {
    "modmenu": ">=12.0.0"
  }
}
