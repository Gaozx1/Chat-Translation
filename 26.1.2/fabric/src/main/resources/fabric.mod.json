{
  "schemaVersion": 1,
  "id": "chattranslation",
  "version": "${version}",
  "name": "Chat Translation",
  "description": "Real-time client-side chat translation mod. Automatically translates chat messages using Google Translate or Bing Translator.",
  "authors": ["ChatTranslation Team"],
  "contact": {
    "homepage": "https://github.com/chattranslation",
    "sources": "https://github.com/chattranslation"
  },
  "license": "MIT",
  "icon": "assets/chattranslation/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.chattranslation.ChatTranslationMod"
    ]
  },
  "depends": {
    "fabricloader": ">=0.15.0",
    "minecraft": "~1.26.1",
    "java": ">=25",
    "fabric-api": ">=0.151.0"
  }
}
